rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 3. Path Variable Hardening
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return (data.xp is number) &&
             (data.stardust is number) &&
             (data.level is number) &&
             (data.get('hp', 100) is number) &&
             (data.get('enemyHp', 500) is number) &&
             (data.get('monsterType', 'GLOOM_MITE') is string) &&
             (data.get('multiplier', 1.0) is number) &&
             (data.get('lastActiveDate', '') == null || data.get('lastActiveDate', '') is string) &&
             (data.get('updatedAt', '') == null || data.get('updatedAt', '') is string) &&
             // 5. Total Array Guarding
             (data.get('quests', []) is list) &&
             (data.get('aiHabits', []) is list) &&
             (data.get('sleepLogs', []) is list) &&
             data.get('quests', []).size() <= 20 &&
             data.get('aiHabits', []).size() <= 20 &&
             data.get('sleepLogs', []).size() <= 30;
    }

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['xp', 'stardust', 'level', 'hp', 'enemyHp', 'monsterType', 'quests', 'aiHabits', 'sleepLogs', 'multiplier', 'lastActiveDate', 'updatedAt']);
      allow delete: if false; // Users cannot delete their profiles via client
    }
  }
}
